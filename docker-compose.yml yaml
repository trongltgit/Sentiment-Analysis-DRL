version: '3.8'

services:
  api:
    build: ./backend
    ports:
      - "8000:8000"
    environment:
      - REDIS_URL=redis://redis:6379/0
      - DATABASE_URL=postgresql://postgres:password@db:5432/sentiment_db
    volumes:
      - ./models:/app/models
      - ./data:/app/data
    depends_on:
      - redis
      - db
    networks:
      - sentiment-network

  frontend:
    build: ./frontend
    ports:
      - "3000:80"
    depends_on:
      - api
    networks:
      - sentiment-network

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    networks:
      - sentiment-network

  db:
    image: postgres:15-alpine
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=password
      - POSTGRES_DB=sentiment_db
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - sentiment-network

  worker:
    build: ./backend
    command: celery -A app.celery worker --loglevel=info
    environment:
      - REDIS_URL=redis://redis:6379/0
      - DATABASE_URL=postgresql://postgres:password@db:5432/sentiment_db
    depends_on:
      - redis
      - db
    networks:
      - sentiment-network

volumes:
  postgres_data:

networks:
  sentiment-network:
    driver: bridge